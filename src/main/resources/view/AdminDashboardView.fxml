<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="600.0" prefWidth="900.0" styleClass="root-pane" stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.controller.AdminController">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12.0" style="-fx-background-color: #14213D; -fx-padding: 12;">
            <Label style="-fx-font-size: 18; -fx-font-weight: bold;" text="ADMIN DASHBOARD" textFill="WHITE" />
            <Button onAction="#refreshData" prefHeight="26.0" prefWidth="106.0" style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-background-radius: 10;" text="Làm mới dữ liệu" />
            <Region HBox.hgrow="ALWAYS" />
            <Button onAction="#logout" style="-fx-background-color: #e74c3c; -fx-background-radius: 10;" text="Đăng xuất" textFill="WHITE" />
        </HBox>
    </top>
    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE">
            <Tab text="Quản lý Người dùng">
                <VBox spacing="10.0">
                    <padding><Insets bottom="10" left="10" right="10" top="10" /></padding>
                    <HBox spacing="8.0">
                        <TextField fx:id="txtSearch" promptText="Tìm kiếm...." HBox.hgrow="ALWAYS" />
                        <Button onAction="#searchUsers" text="Tìm" />
                        <ComboBox fx:id="cbFilterStatus" prefWidth="130.0" />
                        <ComboBox fx:id="cbSortBy" prefWidth="130.0" />
                    </HBox>
                    <TableView fx:id="userTable" prefHeight="426.0" prefWidth="754.0" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="userIdCol" prefWidth="139.20004308223724" text="ID" />
                            <TableColumn fx:id="usernameCol" prefWidth="205.59994506835938" text="Username" />
                            <TableColumn fx:id="emailCol" prefWidth="220.0" text="Email" />
                            <TableColumn fx:id="roleCol" prefWidth="207.99993896484375" text="Role" />
                            <TableColumn fx:id="statusCol" prefWidth="258.4000244140625" text="Status" />
                        </columns>
                    </TableView>
                    <HBox spacing="10.0">
                        <Button onAction="#banUser" style="-fx-background-color: #e74c3c;" text="Khóa tài khoản" textFill="#fffefe" />
                        <Button onAction="#activateUser" style="-fx-background-color: #32CD32;" text="Kích hoạt lại" />
                    </HBox>
                </VBox>
            </Tab>
            <Tab text="Quản lý Phiên đấu giá">
                <VBox spacing="10.0">
                    <padding><Insets bottom="10" left="10" right="10" top="10" /></padding>
               <HBox spacing="8.0">
                  <children>
                     <TextField fx:id="txtAuctionSearch" promptText="Tìm theo mã phiên hoặc sản phẩm..." HBox.hgrow="ALWAYS" />
                     <Button onAction="#searchAuctions" text="Tìm" />
                     <ComboBox fx:id="cbAuctionFilterStatus" prefWidth="130.0" />
                     <ComboBox fx:id="cbAuctionSortBy" prefWidth="130.0" />
                  </children>
               </HBox>
                    <TableView fx:id="auctionTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="auctionIdCol" prefWidth="150.0" text="Mã phiên" />
                            <TableColumn fx:id="itemNameCol" prefWidth="280.0" text="Sản phẩm" />
                            <TableColumn fx:id="currentBidCol" prefWidth="170.0" text="Giá hiện tại" />
                            <TableColumn fx:id="auctionStatusCol" prefWidth="170.0" text="Trạng thái" />
                        </columns>
                    </TableView>
                    <Button onAction="#cancelAuction" style="-fx-background-color: #e74c3c;" text="Hủy phiên đấu giá" textFill="WHITE" />
                </VBox>
            </Tab>
        </TabPane>
    </center>
</BorderPane>
