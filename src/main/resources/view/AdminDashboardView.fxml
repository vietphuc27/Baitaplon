<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
   <top>
      <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: #14213D; -fx-padding: 15;">
         <children>
            <Label prefHeight="30.0" prefWidth="202.0" styleClass="header-title" text="ADMIN DASHBOARD" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="20.0" />
               </font>
            </Label>
            <Label prefHeight="18.0" prefWidth="98.0" text="Hệ thống ổn định" textFill="WHITE" />
            <Button mnemonicParsing="false" prefHeight="26.0" prefWidth="106.0" style="-fx-background-color: #34495e; -fx-background-radius: 10;" text="Làm mới dữ liệu" textFill="#fafafa" />
            <Button layoutX="366.0" layoutY="28.0" mnemonicParsing="false" style="-fx-background-color: #e74c3c; -fx-background-radius: 10;" text="Đăng xuất" textFill="WHITE">
               <HBox.margin>
                  <Insets left="230.0" />
               </HBox.margin>
            </Button>
         </children>
      </HBox>
   </top>
   <center>
      <TabPane prefHeight="200.0" prefWidth="200.0" tabClosingPolicy="UNAVAILABLE" BorderPane.alignment="CENTER">
        <tabs>
          <Tab text="Quản lý Người dùng">
               <content>
                  <VBox spacing="10.0">
                     <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                     </padding>
                      <HBox alignment="CENTER" spacing="8.0">
                          <TextField fx:id="txtSearch" prefHeight="21.0" prefWidth="342.0" promptText="Tìm kiếm tên người dùng..." style="-fx-padding: 5 10; -fx-background-radius: 5; -fx-border-color: #bdc3c7; -fx-border-radius: 5;" HBox.hgrow="ALWAYS">
                              <font><Font size="14.0" /></font>
                          </TextField>
                          <Button style="-fx-background-color: #2980b9; -fx-text-fill: white; -fx-padding: 8 15;" text="Tìm" />
                          <ComboBox fx:id="cbFilterStatus"  prefWidth="120.0" promptText="Trạng thái" style="-fx-padding: 4; -fx-background-color: #f8f9fa; -fx-border-color: #bdc3c7; -fx-border-radius: 5;" />
                          <ComboBox fx:id="cbSortBy" prefWidth="150.0" promptText="Sắp xếp theo" style="-fx-padding: 4; -fx-background-color: #f8f9fa; -fx-border-color: #bdc3c7; -fx-border-radius: 5;" />
                      </HBox>
                     <children>
                        <TableView prefHeight="446.0" prefWidth="779.0">
                          <columns>
                            <TableColumn prefWidth="136.00000607967377" text="ID" />
                            <TableColumn prefWidth="205.5999755859375" text="Tên đăng nhập" />
                              <TableColumn prefWidth="115.20001220703125" text="Vai trò" />
                              <TableColumn minWidth="0.0" prefWidth="153.60000610351562" text="Trạng thái" />
                          </columns>
                        </TableView>
                        <HBox spacing="15.0">
                           <children>
                              <Button mnemonicParsing="false" style="-fx-background-color: #c74444;" text="Khóa tài khoản" textFill="WHITE" />
                              <Button mnemonicParsing="false" style="-fx-background-color: #5ad46d;" text="Kích hoạt lại" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>
               </content>
          </Tab>
            <Tab text="Quản lý Phiên đấu giá">
               <content>
                  <VBox spacing="10.0">
                     <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                     </padding>
                     <children>
                        <TableView fx:id="auctionTable" VBox.vgrow="ALWAYS">
                           <columns>
                              <TableColumn fx:id="auctionIdCol" prefWidth="100.0" text="Mã phiên" />
                              <TableColumn fx:id="itemNameCol" prefWidth="250.0" text="Sản phẩm" />
                              <TableColumn fx:id="currentBidCol" prefWidth="150.0" text="Giá hiện tại" />
                              <TableColumn fx:id="auctionStatusCol" prefWidth="150.0" text="Trạng thái" />
                           </columns>
                        </TableView>
                        <Button style="-fx-background-color: #f39c12; -fx-text-fill: white;" text="Hủy phiên đấu giá" />
                     </children>
                  </VBox>
               </content>
            </Tab>
            <Tab text="Thống kê">
               <content>
                  <VBox alignment="CENTER" spacing="10.0">
                     <children>
                        <Label text="Thống kê doanh thu theo tháng (Năm 2026)">
                           <font>
                              <Font name="System Bold" size="18.0" />
                           </font>
                        </Label>
                        <BarChart>
                          <xAxis>
                            <CategoryAxis label="Tháng" side="BOTTOM" />
                          </xAxis>
                          <yAxis>
                            <NumberAxis label="Doanh thu (Triệu VND)" side="LEFT" />
                          </yAxis>
                        </BarChart>
                     </children>
                     <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                     </padding>
                  </VBox>
               </content>
            </Tab>
        </tabs>
      </TabPane>
   </center>
</BorderPane>
